{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "系统": {
      "type": "object",
      "properties": {
        "项圈状态": {
          "type": "string",
          "enum": [
            "佩戴",
            "摘下"
          ]
        },
        "当前身份": {
          "type": "string",
          "enum": [
            "指挥官",
            "冥灵"
          ]
        },
        "当前时间": {
          "type": "string"
        },
        "当前地点": {
          "type": "string"
        }
      },
      "required": [
        "项圈状态",
        "当前身份",
        "当前时间",
        "当前地点"
      ]
    },
    "冥灵": {
      "type": "object",
      "properties": {
        "身体适应度": {
          "type": "number"
        },
        "淫乱度": {
          "type": "number"
        },
        "攻守值": {
          "type": "number"
        },
        "兴奋度": {
          "type": "number"
        },
        "当前阶段": {
          "type": "string",
          "enum": [
            "新生期",
            "适应期",
            "成长期",
            "完全期"
          ]
        },
        "衣着": {
          "type": "object",
          "properties": {
            "上衣": {
              "type": "string"
            },
            "下衣": {
              "type": "string"
            },
            "内衣": {
              "type": "string"
            },
            "内裤": {
              "type": "string"
            },
            "颈部": {
              "type": "string"
            },
            "手部": {
              "type": "string"
            },
            "腿部": {
              "type": "string"
            },
            "脚部": {
              "type": "string"
            }
          },
          "required": [
            "上衣",
            "下衣",
            "内衣",
            "内裤",
            "颈部",
            "手部",
            "腿部",
            "脚部"
          ]
        },
        "身体状态": {
          "type": "object",
          "properties": {
            "乳房": {
              "type": "string"
            },
            "阴蒂": {
              "type": "string"
            },
            "尿道": {
              "type": "string"
            },
            "小穴": {
              "type": "string"
            },
            "肛门": {
              "type": "string"
            },
            "臀部": {
              "type": "string"
            }
          },
          "required": [
            "乳房",
            "阴蒂",
            "尿道",
            "小穴",
            "肛门",
            "臀部"
          ]
        }
      },
      "required": [
        "身体适应度",
        "淫乱度",
        "攻守值",
        "兴奋度",
        "当前阶段",
        "衣着",
        "身体状态"
      ]
    }
  },
  "required": [
    "系统",
    "冥灵"
  ]
}